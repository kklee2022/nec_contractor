# NEC4 ECC Platform — environment variables
# Copy this to .env and fill in your values

SECRET_KEY=django-insecure-replace-with-a-strong-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite in development)
DB_NAME=nec_db
DB_USER=nec_user
DB_PASSWORD=nec_password
DB_HOST=db
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Email
DEFAULT_FROM_EMAIL=nec-platform@example.com

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:8000/organisation/billing/success/
STRIPE_CANCEL_URL=http://localhost:8000/organisation/billing/
